# Секретный ключ (измените на свой)
SECRET_KEY=your-secret-key-here-change-in-production

# База данных (можно оставить sqlite для разработки)
DATABASE_URL=sqlite:///food_delivery.db

# Настройки SMS (console для разработки, twilio для продакшена)
SMS_PROVIDER=console

# Twilio (раскомментируйте для реальной отправки)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number